{
  "name": "code-test",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write src test",
    "format:check": "prettier --check src test",
    "lint": "eslint src test",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/rosie": "^0.0.45",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.0.0",
    "prettier": "^3.8.1",
    "rosie": "^2.1.1",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.1"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@src/(.*)$": "<rootDir>/src/$1"
    },
    "transform": {
      "^.+\\.[jt]sx?$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!@faker-js/faker)"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "zod": "^4.3.6"
  }
}
