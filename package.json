{
  "name": "code-test",
  "version": "1.0.0",
  "description": "",
  "main": "dist/cli/index.js",
  "bin": "dist/cli/index.js",
  "scripts": {
    "build": "tsc",
    "build:cli": "ncc build src/main.ts -o dist/cli && mkdir -p dist/cli/skills && cp src/ingestion/agent/skills/financial-analyst.md dist/cli/skills/ && cp src/transformation/agent/skills/financial-metric-normaliser.md dist/cli/skills/",
    "build:exe": "yarn build:cli && pkg . --targets node20-macos-x64,node20-win-x64,node20-linux-x64 --output dist/exe/analyser",
    "start": "node dist/cli/index.js",
    "format": "prettier --write src test",
    "format:check": "prettier --check src test",
    "lint": "eslint src test",
    "test": "jest --runInBand --testPathIgnorePatterns=/test/e2e/",
    "test:e2e": "jest --runInBand --testPathPattern=e2e",
    "test:watch": "jest --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/rosie": "^0.0.45",
    "@vercel/ncc": "^0.38.4",
    "@yao-pkg/pkg": "^6.14.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.0.0",
    "prettier": "^3.8.1",
    "rosie": "^2.1.1",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.1"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "moduleNameMapper": {
      "^@src/(.*)$": "<rootDir>/src/$1"
    },
    "transform": {
      "^.+\\.[jt]sx?$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!@faker-js/faker)"
    ]
  },
  "pkg": {
    "assets": "dist/cli/skills/**/*"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "zod": "^4.3.6"
  }
}
